# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Homebrew (inlined — avoids subprocess on every shell)
{{- if eq .chezmoi.os "darwin" }}
export HOMEBREW_PREFIX="/opt/homebrew"
export HOMEBREW_CELLAR="/opt/homebrew/Cellar"
export HOMEBREW_REPOSITORY="/opt/homebrew"
fpath=("$HOMEBREW_PREFIX/share/zsh/site-functions" $fpath)
path=("$HOMEBREW_PREFIX/bin" "$HOMEBREW_PREFIX/sbin" $path)
[ -z "${MANPATH-}" ] || export MANPATH=":${MANPATH#:}"
export INFOPATH="$HOMEBREW_PREFIX/share/info:${INFOPATH:-}"
{{- else if eq .chezmoi.os "linux" }}
export HOMEBREW_PREFIX="/home/linuxbrew/.linuxbrew"
export HOMEBREW_CELLAR="$HOMEBREW_PREFIX/Cellar"
export HOMEBREW_REPOSITORY="$HOMEBREW_PREFIX/Homebrew"
fpath=("$HOMEBREW_PREFIX/share/zsh/site-functions" $fpath)
path=("$HOMEBREW_PREFIX/bin" "$HOMEBREW_PREFIX/sbin" $path)
[ -z "${MANPATH-}" ] || export MANPATH="$HOMEBREW_PREFIX/share/man:${MANPATH#:}"
export INFOPATH="$HOMEBREW_PREFIX/share/info:${INFOPATH:-}"
{{- end }}

# ── Theme ───────────────────────────────────────────────────────────
source {{ .chezmoi.homeDir }}/.zsh/themes/powerlevel10k/powerlevel10k.zsh-theme

# ── History ─────────────────────────────────────────────────────────
HISTFILE="${HISTFILE:-$HOME/.zsh_history}"
HISTSIZE=50000
SAVEHIST=10000
setopt extended_history        # record timestamp
setopt hist_expire_dups_first  # trim duplicates first
setopt hist_ignore_dups        # skip consecutive duplicates
setopt hist_ignore_space       # ignore commands starting with space
setopt hist_verify             # confirm before running history expansion
setopt share_history           # share across sessions

# ── Directory navigation ────────────────────────────────────────────
setopt auto_cd
setopt auto_pushd
setopt pushd_ignore_dups

# ── Completion ──────────────────────────────────────────────────────
autoload -Uz compinit
if [[ -n ~/.zcompdump(#qN.mh-24) ]]; then
  compinit -C   # recent dump — use cached
else
  compinit      # old or missing — full rebuild
fi

# ── Key bindings (emacs mode) ──────────────────────────────────────
bindkey -e
bindkey '^[[H'    beginning-of-line    # Home
bindkey '^[[F'    end-of-line          # End
bindkey '^[[3~'   delete-char          # Delete
bindkey '^[[1;5C' forward-word         # Ctrl+Right
bindkey '^[[1;5D' backward-word        # Ctrl+Left

# ── Editor ──────────────────────────────────────────────────────────
if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR='vim'
else
  export EDITOR='code --wait'
fi

# ── Plugins (sourced directly — no framework overhead) ──────────────
source {{ .chezmoi.homeDir }}/.zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
source {{ .chezmoi.homeDir }}/.zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# fzf keybindings
if (( $+commands[fzf] )); then
  if ! source <(fzf --zsh 2>/dev/null); then
    [[ -f ~/.fzf.zsh ]] && source ~/.fzf.zsh
  fi
fi

# kubectl — lazy-load with disk cache
if (( $+commands[kubectl] )); then
  kubectl() {
    unset -f kubectl
    local cache="${XDG_CACHE_HOME:-$HOME/.cache}/kubectl-completion-zsh"
    if [[ ! -f "$cache" || "$cache" -ot "$(command -v kubectl)" ]]; then
      command kubectl completion zsh > "$cache"
    fi
    source "$cache"
    kubectl "$@"
  }
fi

# ── p10k config ─────────────────────────────────────────────────────
[[ ! -f {{ .chezmoi.homeDir }}/.p10k.zsh ]] || source {{ .chezmoi.homeDir }}/.p10k.zsh

# ── Environment ─────────────────────────────────────────────────────
export PATH=$PATH:$HOME/.local/bin:$HOME/bin
export GPG_TTY=$(tty)

# Go
export PATH=$PATH:/usr/local/go/bin

{{ if eq .chezmoi.os "linux" }}
{{-   if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
# ── WSL2 ────────────────────────────────────────────────────────────
if (( $+commands[keychain] )) && [[ -f ~/.ssh/{{ .sshKeyName }} ]]; then
  eval "$(keychain --quiet --eval --agents ssh {{ .sshKeyName }})"
fi

if [[ -z "$DISPLAY" ]]; then
  export DISPLAY="$(awk '/nameserver/ {print $2; exit}' /etc/resolv.conf):0"
fi

alias pbcopy=clip.exe
alias pbpaste="powershell.exe -Command get-clipboard"

# Flutter/Android (WSL2)
export PKG_CONFIG_PATH=$PKG_CONFIG_PATH:/usr/lib/x86_64-linux-gnu/pkgconfig
export PKG_CONFIG_PATH=$PKG_CONFIG_PATH:/usr/share/pkgconfig
export ANDROID_HOME=$HOME/Android
export PATH="$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/platform-tools:$PATH"
export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
export PATH=$JAVA_HOME/bin:$PATH
export PATH=$PATH:/usr/local/kubebuilder/bin
{{-   end }}
{{- end }}

{{- if eq .chezmoi.os "darwin" }}
# Android Studio bundled JDK (macOS)
if [[ -d "/Applications/Android Studio.app/Contents/jbr/Contents/Home" ]]; then
  export JAVA_HOME="/Applications/Android Studio.app/Contents/jbr/Contents/Home"
  export PATH="$JAVA_HOME/bin:$PATH"
fi
{{- end }}

# ── NVM (lazy-loaded) ──────────────────────────────────────────────
export NVM_DIR="$HOME/.nvm"
if [[ -s "$NVM_DIR/nvm.sh" ]]; then
  __load_nvm() {
    unset -f nvm node npm npx __load_nvm
    \. "$NVM_DIR/nvm.sh"
    [[ -s "$NVM_DIR/bash_completion" ]] && \. "$NVM_DIR/bash_completion"
  }
  nvm()  { __load_nvm; nvm  "$@" }
  node() { __load_nvm; node "$@" }
  npm()  { __load_nvm; npm  "$@" }
  npx()  { __load_nvm; npx  "$@" }
fi

# Google Cloud SDK
[[ -f {{ .chezmoi.homeDir }}/google-cloud-sdk/path.zsh.inc ]] && \
  . {{ .chezmoi.homeDir }}/google-cloud-sdk/path.zsh.inc
[[ -f {{ .chezmoi.homeDir }}/google-cloud-sdk/completion.zsh.inc ]] && \
  . {{ .chezmoi.homeDir }}/google-cloud-sdk/completion.zsh.inc

# Flutter
[[ -d {{ .chezmoi.homeDir }}/develop/flutter/bin ]] && \
  export PATH="{{ .chezmoi.homeDir }}/develop/flutter/bin:$PATH"

# Machine-specific config
[[ -f "$HOME/.kickrc" ]] && source "$HOME/.kickrc"
